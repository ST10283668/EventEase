@model List<EventEase.Models.Event>

<h2>Events</h2>

<p>
    <a asp-action="Create" class="btn-green">Create Event</a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by event, venue, or type" />
        <button type="submit" class="btn-green">Search</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table table-dark table-bordered">
    <thead>
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Venue</th>
            <th>Type</th>
            <th>Start</th>
            <th>End</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrWhiteSpace(e.ImageUrl))
                    {
                        <img src="@Url.Action("Show", "Images", new { name = e.ImageUrl })" alt="@e.EventName" style="width:90px;height:60px;object-fit:cover;" />
                    }
                </td>
                <td>@e.EventName</td>
                <td>@(e.Venue?.VenueName ?? "No Venue")</td>
                <td>@(e.EventType?.TypeName ?? "No Type")</td>
                <td>@e.StartDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@e.EndDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@e.EventId">Details</a> |
                    <a asp-action="Edit" asp-route-id="@e.EventId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@e.EventId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
