@model List<EventEase.Models.Venue>

<h2>Venues</h2>

<p>
    <a asp-action="Create" class="btn-green">Create Venue</a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by name, location, or capacity" />
        <button type="submit" class="btn-green">Search</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table table-dark table-bordered">
    <thead>
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var v in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrWhiteSpace(v.ImageUrl))
                    {
                        <img src="@Url.Action("Show", "Images", new { name = v.ImageUrl })" alt="@v.VenueName" style="width:90px;height:60px;object-fit:cover;" />
                    }
                </td>
                <td>@v.VenueName</td>
                <td>@v.Location</td>
                <td>@v.Capacity</td>
                <td>@v.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@v.VenueId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@v.VenueId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
