@model List<EventEase.Models.Booking>

<h1>Bookings</h1>

<p>
    <a asp-action="Create" class="btn-green">Create Booking</a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by booking ID, reference, event, or venue" />
        <button type="submit" class="btn-green">Search</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table table-dark table-bordered">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Reference</th>
            <th>Venue</th>
            <th>Event</th>
            <th>Location</th>
            <th>Start</th>
            <th>End</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.BookingId</td>
                <td>@b.BookingReference</td>
                <td>@(b.Venue?.VenueName ?? "No Venue")</td>
                <td>@(b.Event?.EventName ?? "No Event")</td>
                <td>@(b.Venue?.Location ?? "-")</td>
                <td>@b.StartDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@b.EndDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@b.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@b.BookingId">Details</a> |
                    <a asp-action="Edit" asp-route-id="@b.BookingId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@b.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
